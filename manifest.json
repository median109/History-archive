{
  "manifest_version": 3,
  "name": "浏览器历史定时导出器",
  "version": "1.1",
  "description": "定时导出浏览器历史记录，用于归档和搜索。",
  "permissions": ["history", "downloads", "storage", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "历史导出器"
  }
}